# ==========================================
# Vercel 无脑配置（只填厂商 Key）
# 每个厂商 1 个 Key，配置数量 = 厂商数量
# ==========================================
OPENAI_KEY=
GOOGLE_KEY=
ALI_KEY=
BYTE_KEY=
MINIMAX_KEY=
ZHIPU_KEY=

# ==========================================
# 可选高级配置（默认不用改）
# ==========================================
AI_UPSTREAM_TIMEOUT_MS=25000
AI_GOOGLE_TIMEOUT_MS=25000
AI_RATE_LIMIT_RPM=120

# 可选：网关令牌（仅在 AI_GATEWAY_REQUIRE_TOKEN=1 时生效）
AI_GATEWAY_TOKEN=
# 可选：显式开启网关鉴权（1=开启，0=关闭；默认关闭）
AI_GATEWAY_REQUIRE_TOKEN=0

# 可选：Postgres（建议和 Blob 一起用）
POSTGRES_URL=
DATABASE_URL=
PRISMA_DATABASE_URL=

# 历史接口默认复用 AI_GATEWAY_TOKEN；可单独覆盖
HISTORY_GATEWAY_TOKEN=
# 可选：显式开启历史接口鉴权（1=开启，0=关闭；默认跟随 AI_GATEWAY_REQUIRE_TOKEN）
HISTORY_GATEWAY_REQUIRE_TOKEN=0
# 可选：Edge Config 运行时策略缓存（毫秒）
HISTORY_EDGE_CONFIG_CACHE_MS=10000
# 历史数据模式：blob | hybrid | postgres
HISTORY_DATABASE_MODE=hybrid

# 历史上传限制（防止滥用和成本攻击）
HISTORY_MAX_BODY_BYTES=12582912
HISTORY_MAX_FRAMES_PER_RECORD=80
HISTORY_MAX_IMAGE_BYTES=8388608
HISTORY_MAX_TOTAL_IMAGE_BYTES=50331648

# 可选：Vercel Edge Config 连接串（用于 history 运行时策略）
# 典型由 Vercel 自动注入，无需手填
EDGE_CONFIG=

# 运行时模型别名请维护在 config/ai-runtime-aliases.json

# 可选：覆盖默认 Base URL（通常不需要）
OPENAI_BASE_URL=
ALI_BASE_URL=
BYTE_BASE_URL=
MINIMAX_BASE_URL=
ZHIPU_BASE_URL=

# 可选：前端开发态配置
VITE_USE_BACKEND=1
VITE_API_BASE_URL=
VITE_BACKEND_DEV_URL=
VITE_PROXY_BASE_URL=https://xh.v1api.cc/v1
