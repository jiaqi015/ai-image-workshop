# ==========================================
# Vercel 无脑配置（只填厂商 Key）
# 每个厂商 1 个 Key，配置数量 = 厂商数量
# ==========================================
OPENAI_KEY=
GOOGLE_KEY=
ALI_KEY=
BYTE_KEY=
MINIMAX_KEY=
ZHIPU_KEY=

# ==========================================
# 可选高级配置（默认不用改）
# ==========================================
AI_UPSTREAM_TIMEOUT_MS=25000
AI_GOOGLE_TIMEOUT_MS=25000
AI_RATE_LIMIT_RPM=120
AI_GATEWAY_TOKEN=

# 可选：模型别名映射（用于厂商真实运行时 ID，如字节 ep-接入点）
# 示例:
# AI_MODEL_ALIASES_JSON={"byte":{"doubao-seed-2-0-pro":"ep-2026xxxxx","doubao-seedream-5-0-lite":"ep-2026yyyyy"}}
AI_MODEL_ALIASES_JSON=

# 可选：覆盖默认 Base URL（通常不需要）
OPENAI_BASE_URL=
ALI_BASE_URL=
BYTE_BASE_URL=
MINIMAX_BASE_URL=
ZHIPU_BASE_URL=

# 可选：前端开发态配置
VITE_USE_BACKEND=1
VITE_API_BASE_URL=
VITE_BACKEND_DEV_URL=
VITE_PROXY_BASE_URL=https://xh.v1api.cc/v1
