# ===== Frontend Runtime =====
# Keep VITE_USE_BACKEND=1 in production
VITE_USE_BACKEND=1
# Optional: local frontend -> remote backend
VITE_API_BASE_URL=
# Optional: Vite dev proxy target (for local split frontend/backend)
VITE_BACKEND_DEV_URL=
# Optional: local fallback proxy in frontend-only mode
VITE_PROXY_BASE_URL=https://xh.v1api.cc/v1

# ===== Provider Keys (comma or newline separated) =====
# Example: OPENAI_KEYS=sk-a,sk-b,sk-c
OPENAI_KEYS=
GOOGLE_KEYS=
ALI_KEYS=
BYTE_KEYS=
MINIMAX_KEYS=
ZHIPU_KEYS=

# ===== Provider Base URLs (OpenAI-compatible providers) =====
OPENAI_BASE_URL=https://api.openai.com/v1
ALI_BASE_URL=
BYTE_BASE_URL=
MINIMAX_BASE_URL=
ZHIPU_BASE_URL=

# ===== Legacy single-key aliases (optional) =====
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ALI_API_KEY=
BYTE_API_KEY=
MINIMAX_API_KEY=
ZHIPU_API_KEY=
